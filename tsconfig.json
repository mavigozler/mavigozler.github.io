{
  "extends": "./node_modules/@microsoft/rush-stack-compiler-4.7/includes/tsconfig-web.json",
  "compilerOptions": {
    "target": "es5",
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react",
    "declaration": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "outDir": "lib",
    "inlineSources": false,
    "noImplicitAny": true,
   // "rootDir": "D:/dev/_Projects/ChemCalcSPFx/src",
    "baseUrl": "./",
    "paths": {
      "@ChemCalc/*": [ "src/ChemCalc/*" ],
      "@GenLib/*": [ "src/GenLib/*" ],
      "@SPREST/*": [ "src/SPREST/*" ]
    },

    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@microsoft"
    ],
    "types": [
      "webpack-env"
    ],
    "lib": [
      "es5",
      "dom",
      "es2015.collection",
      "es2015.promise",
      "ES2019"
    ]
  },
  "include": [
    "src/webparts/**/*.ts",
    "src/webparts/**/*.tsx"
  ],
  "exclude": [
  //  "src/ChemCalc/*"
  ]
}
